# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override Anthropic base URL (e.g. for Ollama via anthropic backend)
# ANTHROPIC_BASE_URL=http://your-ollama-host:port/

# OpenAI-compatible API Configuration (used by the openai backend)
# Defaults to http://localhost:11434/v1 (local Ollama)
# OPENAI_BASE_URL=http://your-ollama-host:port/v1
# OPENAI_API_KEY=ollama
